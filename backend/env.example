# Copy to .env and adjust:  Copy-Item env.example .env
NODE_ENV=development
PORT=8080

# Postgres + PostGIS (matches docker-compose)
DATABASE_URL=postgresql://spandan:spandan@localhost:5432/spandan

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-to-a-long-random-secret-min-16-chars
JWT_EXPIRES_IN=24h

# Phase 2 model service
AI_SERVICE_URL=http://localhost:8001
AI_TIMEOUT_MS=30000

# Object storage (MinIO / S3)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=spandan
S3_SECRET_KEY=spandan-secret
S3_BUCKET=spandan-observations

# Inference queue (note: BullMQ queue names must NOT contain ':')
INFERENCE_QUEUE=spandan-inference
WORKER_CONCURRENCY=4

# HTTP
CORS_ORIGIN=*

# Auto-bind an observation to the nearest asset within this many metres
ASSET_MATCH_RADIUS_M=60

S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_URL=http://localhost:9000/spandan-observations
