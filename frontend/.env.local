# Spandan frontend environment (Next.js PWA)

# Base URL of the Phase 3 backend API.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1

# Optional (Phase 5): presigned upload endpoint. When unset, captured photos are
# inlined as compact JPEG data URLs, which the backend accepts as imageUrl.
# NEXT_PUBLIC_UPLOAD_URL=
